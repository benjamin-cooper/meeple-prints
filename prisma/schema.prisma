// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// A board game from the connected BGG collection.
model Game {
  id            Int      @id @default(autoincrement())
  bggId         Int      @unique
  name          String
  yearPublished Int?
  thumbnail     String?
  image         String?
  minPlayers    Int?
  maxPlayers    Int?
  inCollection  Boolean  @default(true)
  addedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastScannedAt DateTime? // last time "Search all sites" ran for this game

  products         Product[]
  discoveredPrints DiscoveredPrint[]
}

// A saved 3D-printable accessory: an insert, organizer, miniature proxy,
// terrain piece, token replacement, etc. found on any print-sharing site.
model Product {
  id              Int      @id @default(autoincrement())
  url             String   @unique
  title           String
  description     String?
  thumbnailUrl    String?
  domain          String   // host the link points to, e.g. "thingiverse.com"
  siteName        String?  // human label, e.g. "Thingiverse"
  type            String   @default("other") // insert, organizer, miniature, terrain, token, tuckbox, dice-tower, other
  creator         String?
  price           Float?
  currency        String?  @default("USD")
  isFree          Boolean  @default(false)
  status          String   @default("wishlist") // wishlist | queued | printed | installed
  rating          Int?     // 1-5 personal usefulness rating, set by you
  siteRating      Float?   // 0-5 average rating from the source site, Printables only
  siteRatingCount Int?     // review count backing siteRating
  siteLikesCount  Int?     // like/favorite count, Thingiverse + Cults3D only
  notes           String?
  tags            String?  // JSON-encoded string[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  games Game[]
}

// A cached, relevance-filtered search hit for a game, refreshed on a
// schedule. Not yet "saved" -- promoting one into a Product is what saving
// means. Upserted by (gameId, url) on every scan.
model DiscoveredPrint {
  id           Int      @id @default(autoincrement())
  gameId       Int
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  url          String
  title        String
  thumbnailUrl String?
  domain       String
  siteName     String?
  type         String   @default("other")
  creator      String?
  price        Float?
  currency     String?
  isFree       Boolean  @default(false)
  rating       Float?
  ratingCount  Int?
  likesCount   Int?
  hidden       Boolean  @default(false) // dismissed as "not relevant" -- scans never reset this back to false
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @updatedAt

  @@unique([gameId, url])
}

// Single-row settings for the connected BGG collection. This is a personal,
// single-household tool, so the BGG session lives here rather than behind
// a full multi-user auth system. Search provider credentials (Thingiverse,
// Cults3D, Etsy) live in environment variables instead of here, since
// they're static secrets rather than something that needs a "reconnect"
// flow, and env vars don't need manually syncing between environments.
model Settings {
  id                 String    @id @default("singleton")
  bggUsername        String?
  bggSessionId       String?
  lastCollectionSync DateTime?
  lastCronRunAt      DateTime? // last time /api/cron/scan completed successfully
}
