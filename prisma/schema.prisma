// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// A board game from the connected BGG collection.
model Game {
  id            Int      @id @default(autoincrement())
  bggId         Int      @unique
  name          String
  yearPublished Int?
  thumbnail     String?
  image         String?
  minPlayers    Int?
  maxPlayers    Int?
  inCollection  Boolean  @default(true)
  addedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastScannedAt DateTime? // last time "Search all sites" ran for this game

  products Product[]
}

// A saved 3D-printable accessory: an insert, organizer, miniature proxy,
// terrain piece, token replacement, etc. found on any print-sharing site.
model Product {
  id           Int      @id @default(autoincrement())
  url          String   @unique
  title        String
  description  String?
  thumbnailUrl String?
  domain       String   // host the link points to, e.g. "thingiverse.com"
  siteName     String?  // human label, e.g. "Thingiverse"
  type         String   @default("other") // insert, organizer, miniature, terrain, token, tuckbox, dice-tower, other
  creator      String?
  price        Float?
  currency     String?  @default("USD")
  isFree       Boolean  @default(false)
  status       String   @default("wishlist") // wishlist | queued | printed | installed
  rating       Int?     // 1-5 personal usefulness rating
  notes        String?
  tags         String?  // JSON-encoded string[]
  source       String   @default("manual") // manual | geeklist_import
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  games Game[]
}

// Single-row settings for the connected BGG collection. This is a personal,
// single-household tool, so the BGG session lives here rather than behind
// a full multi-user auth system. Search provider credentials (Thingiverse,
// Cults3D, Etsy) live in environment variables instead of here, since
// they're static secrets rather than something that needs a "reconnect"
// flow, and env vars don't need manually syncing between environments.
model Settings {
  id                 String    @id @default("singleton")
  bggUsername        String?
  bggSessionId       String?
  lastCollectionSync DateTime?
  lastGeeklistSync   DateTime?
}
