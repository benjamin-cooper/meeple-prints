DATABASE_URL="file:./prisma/dev.db"
# For a hosted database (e.g. Turso), use a libsql:// URL here instead
# and set DATABASE_AUTH_TOKEN below. Local SQLite doesn't need either.
DATABASE_AUTH_TOKEN=""

# Random string used to sign the site's login session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# The only BGG username allowed to log in. A login attempt for any other
# username is rejected before it ever reaches BGG.
OWNER_BGG_USERNAME=""

# Optional: enables automatic search for each site. Printables needs none
# of these and always works. See the Connect page for where to get each one.
THINGIVERSE_TOKEN=""
CULTS_USERNAME=""
CULTS_API_KEY=""
ETSY_KEYSTRING=""
ETSY_SHARED_SECRET=""
MYMINIFACTORY_API_KEY=""

# Verifies that the daily scan cron actually came from Vercel and not a
# public crawler hitting the same path. Vercel sends this automatically as
# "Authorization: Bearer $CRON_SECRET" when the env var is set.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# How many games the daily scan sweeps per run. Kept conservative by
# default since Vercel's free tier caps function duration at 10s regardless
# of maxDuration; raise it if your cron logs show plenty of headroom.
AUTO_SCAN_BATCH_SIZE="10"
